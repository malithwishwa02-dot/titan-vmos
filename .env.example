# Titan V13.0 — Environment Configuration
# Copy to .env and fill in values

# API Authentication
TITAN_API_SECRET=change-me-to-a-secure-random-string

# API Port (used by workflow engine internal calls)
TITAN_API_PORT=8080

# CORS — comma-separated list of allowed origins for the API server
# Default is localhost only. Add your VPS hostname/IP if needed.
TITAN_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080

# Data paths
TITAN_DATA=/opt/titan/data

# GPU / AI
TITAN_GPU_URL=http://127.0.0.1:8765
TITAN_GPU_OLLAMA=http://127.0.0.1:11435
TITAN_CPU_OLLAMA=http://127.0.0.1:11434

# Model assignments — per-task routing to optimal Titan-trained model
TITAN_AGENT_MODEL=titan-agent:7b
TITAN_SPECIALIST_MODEL=titan-specialist:7b-v2
TITAN_VISION_MODEL=minicpm-v:8b
TITAN_TRAINED_ACTION=titan-agent:7b
TITAN_TRAINED_VISION=minicpm-v:8b
TITAN_UNCENSORED_MODEL=fast-uncensored:latest
TITAN_ROLEPLAY_MODEL=lightning-roleplay:latest
TITAN_GENERAL_MODEL=llama3.1:8b

# Cuttlefish paths
CVD_BIN_DIR=/opt/titan/cuttlefish/cf/bin
CVD_IMAGES_DIR=/opt/titan/images
CVD_HOME_BASE=/opt/titan/cuttlefish

# CORS (comma-separated origins, default: allow localhost only)
TITAN_CORS_ORIGINS=https://localhost

# Hostinger VPS API (optional)
HOSTINGER_API_TOKEN=

# Vast.ai GPU Instance (SSH tunnel for Ollama + GPU services)
VASTAI_API_KEY=
VASTAI_INSTANCE_ID=
VASTAI_HOST=
VASTAI_SSH_PORT=

# Alert webhook (optional — Slack/Discord)
TITAN_ALERT_WEBHOOK=

# ═══════════════════════════════════════════════════════════════════════
# VMOS Cloud API (for cloud phone device management)
# Get credentials from your VMOS Cloud dashboard
# ═══════════════════════════════════════════════════════════════════════
VMOS_API_KEY=
VMOS_API_SECRET=
VMOS_API_HOST=api.vmoscloud.com
