{
  "name": "titan-console",
  "version": "13.0.0",
  "description": "Titan V13.0 Cuttlefish Android Console — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "build:deb": "electron-builder --linux deb",
    "build:appimage": "electron-builder --linux AppImage",
    "build:all": "electron-builder --linux deb AppImage"
  },
  "author": {
    "name": "Titan",
    "email": "dev@titan.local"
  },
  "homepage": "https://github.com/malithwishwa02-dot/titan-vmos",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.titan.console",
    "productName": "Titan Console",
    "extraResources": [
      {
        "from": "../core",
        "to": "core",
        "filter": ["**/*.py", "**/*.json", "!__pycache__/**", "!_deprecated/**"]
      },
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*.py", "**/*.txt", "**/*.json", "!__pycache__/**"]
      },
      {
        "from": "../console",
        "to": "console",
        "filter": ["**/*", "!**/*.bak"]
      },
      {
        "from": "../scripts",
        "to": "scripts",
        "filter": ["**/*.sh", "**/*.py", "!_deprecated/**", "!__pycache__/**"]
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "desktop": {
        "Name": "Titan Console",
        "Comment": "Titan V13.0 Cuttlefish Android Console",
        "Keywords": "titan;android;cuttlefish;antidetect;console;",
        "StartupWMClass": "titan-console",
    "Version": "13.0.0"
      }
    },
    "deb": {
      "depends": [
        "python3 (>= 3.10)",
        "python3-venv",
        "python3-pip",
        "adb"
      ],
      "afterInstall": "scripts/postinstall.sh",
      "fpm": ["--name", "titan-console"]
    },
    "appImage": {
      "artifactName": "Titan-Console-${version}-${arch}.AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "assets/**",
      "package.json"
    ]
  }
}
